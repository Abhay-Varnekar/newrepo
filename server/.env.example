# Razorpay Credentials
# Get these from your Razorpay Dashboard: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys for development, rzp_live_... for production

RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Server Configuration
PORT=5000

# Frontend URL (for CORS) — change to your production domain in production
FRONTEND_URL=http://localhost:5173
