# Razorpay Credentials
# Get these from your Razorpay Dashboard: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... keys for development, rzp_live_... for production

RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Server Configuration
PORT=5000

# Frontend URL (for CORS) — change to your production domain in production
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Email / SMTP — for sending receipt PDFs to customers after payment
# ---------------------------------------------------------------------------
# For Gmail:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com/apppasswords and generate an App Password
#   3. Use that 16-character password as SMTP_PASS (NOT your regular Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=TimesAspire Receipts <your-email@gmail.com>
COMPANY_EMAIL=your-company-email@domain.com
